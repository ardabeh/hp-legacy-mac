#!/bin/sh
# hp-legacy-mac CUPS filter (generic)
# Replaces foomatic-rip; reads a per-queue config based on the connected model.
# Because the macOS CUPS sandbox blocks exec from /usr/local and /opt/homebrew,
# all dependencies live under BASE (a sandbox-allowed location).
#
# CUPS filter arguments: 1=job 2=user 3=title 4=copies 5=options [6=file]
# CUPS also sets the $PRINTER environment variable to the queue name.

BASE=/Library/Printers/hp-legacy-mac
export PATH="$BASE/bin:/usr/bin:/bin"
export GS_LIB="$BASE/share/ghostscript/Resource/Init:$BASE/share/ghostscript/lib:$BASE/share/ghostscript/Resource/Font:$BASE/share/ghostscript/fonts"
GS="$BASE/bin/gs"

# --- Per-queue defaults ---
DRIVER="foo2zjs-wrapper -z3 -P -L0"   # wrapper + driver options
COLOR_CAPABLE=0                        # 1 enables color detection
COLOR_FLAGS="-c -C gs9"               # ICC color path that works on gs 10.x

CONF="$BASE/queues/${PRINTER}.conf"
[ -r "$CONF" ] && . "$CONF"

# --- Color mode: decide from job options (color unless mono is explicitly requested) ---
COLOR=""
if [ "$COLOR_CAPABLE" = "1" ]; then
    COLOR="$COLOR_FLAGS"
    case "$5" in
        *Monochrome*|*monochrome*|*Grayscale*|*grayscale*|*ColorModel=Gray*|*print-color-mode=monochrome*)
            COLOR="" ;;
    esac
fi

# --- Run the pipeline ---
if [ -n "$6" ]; then
    exec $DRIVER $COLOR -b "$GS" < "$6"
else
    exec $DRIVER $COLOR -b "$GS"
fi
